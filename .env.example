# Copy this file to .env and fill in your actual Supabase project values.
# Never commit the real .env file to version control.
#
# ─── Local / demo mode ───────────────────────────────────────────────────────
# If you do NOT rename this file (or leave the placeholder values below),
# the app runs in full local/demo mode automatically:
#   • No login required — a demo account is used.
#   • All data is stored in the browser's localStorage.
#   • Every module is unlocked and fully usable.
# This is ideal for quick local testing without setting up Supabase.
#
# ─── Production / full mode ──────────────────────────────────────────────────
# Create a project at https://supabase.com, copy the values below, then run:
#   cp .env.example .env
# and fill in the real values.

VITE_SUPABASE_PROJECT_ID=your_supabase_project_id
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key
VITE_SUPABASE_URL=https://your_project_ref.supabase.co
